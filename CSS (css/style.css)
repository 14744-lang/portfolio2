*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Segoe UI',sans-serif;
}

body{
    background:#f4fbff;
    color:#333;
}

header{
    background:#4da6ff;
    color:white;
    padding:20px;
}

nav{
    display:flex;
    justify-content:center;
    gap:25px;
}

nav a{
    color:white;
    text-decoration:none;
    font-weight:bold;
}

nav a:hover{
    color:#dff5ff;
}

.hero{
    text-align:center;
    padding:80px 20px;
}

.hero img{
    width:180px;
    border-radius:50%;
    border:5px solid #66b3ff;
}

.hero h1{
    margin-top:20px;
    color:#2196F3;
}

.container{
    width:85%;
    margin:auto;
    padding:40px 0;
}

.card{
    background:white;
    padding:25px;
    margin:20px 0;
    border-radius:15px;
    box-shadow:0 5px 15px rgba(0,0,0,.1);
}

footer{
    background:#4da6ff;
    color:white;
    text-align:center;
    padding:15px;
    margin-top:40px;
}

.gallery{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:20px;
}

.gallery img{
    width:100%;
    border-radius:10px;
}

.contact a{
    display:block;
    margin:10px 0;
    color:#2196F3;
    text-decoration:none;
}
